# Nemotron inference server
NEMO_API_BASE=http://100.125.50.95:1237
# Default model (available: nemotron-3-nano, nemotron-3-nano-4b, gemma-4-26b-a4b, qwen/qwen3.5-35b-a3b, gemma-3n-e4b)
DEFAULT_MODEL=nvidia/nemotron-3-nano-4b
NEMO_MODEL=nvidia/nemotron-3-nano-4b

# System prompt (optional)
NEMO_SYSTEM_PROMPT=You are a helpful AI assistant powered by NVIDIA Nemotron.

# Server config
NEMO_PORT=8091
NEMO_HOST=0.0.0.0

# Max conversation history turns
NEMO_MAX_HISTORY=50

# Gitea (local Git server)
GITEA_URL=http://localhost:3000
GITEA_TOKEN=
GITEA_OWNER=nemo
GITEA_WEBHOOK_SECRET=

# RAG / Embeddings
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
CHROMA_DIR=./chromadb_data
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5
